<view class="tab-bar theme-{{resolvedTheme}}">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="tab-icon {{selected === index ? 'active' : ''}}">{{item.icon}}</text>
    <text class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</text>
  </view>
</view>
