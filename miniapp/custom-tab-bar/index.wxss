.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(72rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  z-index: 9999;
  border-top: 1px solid #464343;
  background: #1a1717;
}

.tab-bar.theme-light {
  border-top-color: #d2d2d7;
  background: #ffffff;
}

.tab-bar.theme-dark {
  border-top-color: #464343;
  background: #1a1717;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding-top: 6rpx;
}

.tab-icon {
  font-size: 30rpx;
  line-height: 1;
  color: #9a9898;
}

.tab-icon.active {
  color: #007aff;
}

.tab-text {
  font-size: 18rpx;
  color: #9a9898;
}

.tab-text.active {
  color: #007aff;
  font-weight: 600;
}

.tab-bar.theme-light .tab-icon,
.tab-bar.theme-light .tab-text {
  color: #86868b;
}

.tab-bar.theme-light .tab-icon.active,
.tab-bar.theme-light .tab-text.active {
  color: #007aff;
}
