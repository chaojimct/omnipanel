{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "OmniPanel",
  "version": "0.0.5",
  "identifier": "com.omnipanel.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmniPanel",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": ["style-src"],
      "csp": {
        "default-src": "'self' asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost https://github.com http://localhost:* https://localhost:* ws://localhost:* wss://localhost:*",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "worker-src": "'self' blob:",
        "img-src": "'self' asset: http://asset.localhost data: blob: https: http:",
        "font-src": "'self' data:",
        "frame-src": "'self' asset: http://asset.localhost https: http:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzN0I1NTMwNDAxMjk4RDQKUldUVW1CSkFNRlY3WS93eHV1UFhObjliRzFJMnFhaldpMnpBYnNTVFdoNEhYSHlKS2g1Z2MzZEIK",
      "endpoints": [
        "https://xget.xi-xu.me/gh/chaojimct/omnipanel/releases/latest/download/latest.json",
        "https://github.com/chaojimct/omnipanel/releases/latest/download/latest.json"
      ]
    }
  }
}
