# Agent Configuration
AGENT_NAME=OmniPanel Agent
AGENT_DESCRIPTION=An intelligent AI agent for the OmniPanel ecosystem
AGENT_CAPABILITIES=task_execution,conversation,code_generation,data_analysis

# Model Configuration
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_API_KEY=your-api-key-here
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# ACP Server Configuration
ACP_HOST=0.0.0.0
ACP_PORT=3100
ACP_AUTH_ENABLED=false
ACP_AUTH_TOKEN=your-secret-token

# Memory Configuration
MEMORY_ENABLED=true
MEMORY_MAX_HISTORY=100

# Logging
LOG_LEVEL=info
